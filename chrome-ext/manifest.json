{
  "manifest_version": 3,
  "name": "TokenPUA",
  "version": "1.0.0",
  "description": "实时显示 Token 额度使用进度",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://token.woa.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://token.woa.com/*"],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://token.woa.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TokenPUA"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
