{
  "manifest_version": 3,
  "name": "TokenPUA",
  "version": "1.0.0",
  "description": "macOS 菜单栏工具 TokenPUA 的 Chrome 扩展版 — 实时显示 Token 额度使用进度",
  "permissions": ["alarms", "storage", "cookies"],
  "host_permissions": ["https://*.woa.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TokenPUA"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
